# ── Security & API Keys ───────────────────────────────────

# The Google Gemini API key used by the MCP server for AI chat
GEMINI_API_KEY=your_gemini_api_key_here

# The secret key used for signing JWT tokens across microservices
JWT_SECRET=your_super_secret_jwt_key_here

# ── Database (Optional Overrides) ─────────────────────────
# DB_USERNAME=paysense
# DB_PASSWORD=paysense123

# ── Payment Gateway ───────────────────────────────────────
# Razorpay API Keys (Test or Prod)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
